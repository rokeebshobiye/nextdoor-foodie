generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Administrator {
  id  Int
  roleId  Int
  authId  Int
  gender  String
  dob  String
  address  String
  city  String
  country  String
  role_id  Int
  auth_id  Int
  profile_picture  String
  first_name  String
  last_name  String
  other_name  String
  phone_number  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  auth  Auth  @relation(fields: [authId], references: [id])

  @@map("administrators")
}

model AdminRole {
  id  Int
  admin_id  Int
  role_id  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  role  Role  @relation(fields: [role_id], references: [id])

  @@map("admin_roles")
}

model Advert {
  id  Int
  banner_id  Int
  title  String
  description  String
  headline  String
  cta  Json
  sort_order  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  background  String
  start_date  String
  end_date  String
  upload  Upload  @relation(fields: [banner_id], references: [id])

  @@map("adverts")
}

model AnalyticsEvent {
  id  Int
  event_type  String
  brand_id  Int
  promo_id  Int
  user_id  Int
  admin_id  Int
  review_id  Int
  session_id  String
  payout_id  Int
  value  Float
  count  Int
  meta_data  Json
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("analytics_events")
}

model Auth {
  id  Int
  email  String
  password  String
  provider_user_id  String
  status  String
  is_email_verified  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  administrator  Administrator[]
  user  User[]

  @@map("auths")
}

model Brand {
  id  Int
  logo_id  Int
  name  String
  email  String
  description  String
  category  String
  phone_number  String
  address  String
  city  String
  state  String
  country  String
  slug  String
  is_verified  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  upload  Upload  @relation(fields: [logo_id], references: [id])
  brandAnalytic  BrandAnalytic[]
  event  Event[]
  location  Location[]
  promo  Promo[]
  reservation  Reservation[]

  @@map("brands")
}

model BrandAnalytic {
  id  Int
  date  DateTime
  brand_id  Int
  promos_created  Int
  impressions  Int
  redemptions  Int
  active_customers  Int
  revenue  Float
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  platform_commission  Float
  brand  Brand  @relation(fields: [brand_id], references: [id])

  @@map("brand_analytics")
}

model Category {
  id  Int
  image_id  Int
  name  String
  slug  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  upload  Upload  @relation(fields: [image_id], references: [id])

  @@map("categories")
}

model Device {
  id  Int
  owner_id  Int
  owner_type  String
  device_name  String
  fingerprint  String
  device_token  String
  device_type  String
  notification_enabled  Int
  operating_system  String
  meta_data  Json
  status  String
  last_login_at  DateTime
  created_at  DateTime
  updated_at  DateTime
  device_id  String

  @@map("devices")
}

model EmailVerification {
  id  Int
  email  String
  type  String
  code  String
  user_id  Int
  verified_at  DateTime
  expired_at  DateTime
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("email_verifications")
}

model Event {
  id  Int
  brand_id  Int
  image_id  Int
  name  String
  description  String
  location  String
  max_attendees  Int
  time  String
  status  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  price  Int
  slug  String
  date  String
  brand  Brand  @relation(fields: [brand_id], references: [id])

  @@map("events")
}

model Location {
  id  Int
  brand_id  Int
  name  String
  address  String
  city  String
  state  String
  country  String
  latitude  Float
  longitude  Float
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  brand  Brand  @relation(fields: [brand_id], references: [id])

  @@map("locations")
}

model Notification {
  id  Int
  title  String
  content  String
  owner_id  Int
  owner_type  String
  source_id  Int
  meta_data  Json
  read_at  DateTime
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("notifications")
}

model Order {
  id  Int
  user_id  Int
  item_id  Int
  item_type  String
  transaction_id  Int
  amount  Float
  status  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  brand_id  Int
  transaction  Transaction  @relation(fields: [transaction_id], references: [id])

  @@map("orders")
}

model Payout {
  id  Int
  brand_id  Int
  payout_account_id  Int
  amount  Float
  status  String
  method  String
  reference  String
  fee  Float
  initiated_at  DateTime
  processed_at  DateTime
  meta_data  Json
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("payouts")
}

model PayoutAccount {
  id  Int
  brand_id  Int
  bank_code  String
  account_name  String
  account_number  String
  is_primary  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("payout_accounts")
}

model Permission {
  id  Int
  name  String
  slug  String
  scope  String
  http_method  String
  http_path  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("permissions")
}

model Promo {
  id  Int
  brand_id  Int
  image_id  Int
  name  String
  description  String
  price  Float
  terms  String
  locations  Json
  avg_rating  Float
  reviews_count  Int
  redemptions_count  Int
  eligibility  String
  start_date  DateTime
  likes_count  Int
  end_date  DateTime
  status  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  slug  String
  brand  Brand  @relation(fields: [brand_id], references: [id])
  promoVoucher  PromoVoucher[]

  @@map("promos")
}

model PromoAnalytic {
  id  Int
  date  DateTime
  brand_id  Int
  promo_id  Int
  impressions  Int
  clicks  Int
  favorites  Int
  redemptions  Int
  active_customers  Int
  reviews_count  Int
  avg_rating  Float
  revenue  Float
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("promo_analytics")
}

model PromoLike {
  id  Int
  promo_id  Int
  user_id  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  user  User  @relation(fields: [user_id], references: [id])

  @@map("promo_likes")
}

model PromoVoucher {
  id  Int
  order_id  Int
  location_id  Int
  handler_id  Int
  expires_at  DateTime
  redeemed_at  DateTime
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  status  String
  code  String
  brand_id  Int
  user_id  Int
  promo_id  Int
  promo  Promo  @relation(fields: [promo_id], references: [id])

  @@map("promo_vouchers")
}

model Reservation {
  id  Int
  event_id  Int
  brand_id  Int
  user_id  Int
  code  String
  status  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  order_id  Int
  brand  Brand  @relation(fields: [brand_id], references: [id])

  @@map("reservations")
}

model Review {
  id  Int
  promo_id  Int
  user_id  Int
  rating  Int
  comment  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("reviews")
}

model Role {
  id  Int
  name  String
  description  String
  slug  String
  permissions  Json
  owner_id  Int
  owner_type  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  adminRole  AdminRole[]

  @@map("roles")
}

model Subscription {
  id  Int
  subscription_plan_id  Int
  brand_id  Int
  status  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  start_date  String
  end_date  String
  subscriptionPlan  SubscriptionPlan  @relation(fields: [subscription_plan_id], references: [id])

  @@map("subscriptions")
}

model SubscriptionPlan {
  id  Int
  billingInterval  String
  currencyCode  String
  price  Int
  package  String
  description  String
  features  Json
  createdAt  DateTime
  updatedAt  DateTime
  deletedAt  DateTime
  subscription  Subscription[]

  @@map("subscription_plans")
}

model SystemAnalytic {
  id  Int
  date  DateTime
  total_users  Int
  daily_avg_users  Int
  new_users  Int
  avg_session_minutes  Float
  most_popular_location  String
  top_user_actions  Json
  top_locations  Json
  active_brands  Int
  pending_brands  Int
  flagged_brands  Int
  active_promos  Int
  pending_promos  Int
  flagged_promos  Int
  rejected_promos  Int
  impressions  Int
  redemptions  Int
  revenue  Float
  commission  Float
  pending_payouts  Float
  completed_payouts  Float
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("system_analytics")
}

model SystemSetting {
  id  Int
  key  String
  value  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("system_settings")
}

model Transaction {
  id  Int
  reference  String
  amount  Float
  status  String
  brand_id  Int
  currency_code  String
  payment_provider  String
  payment_method  String
  meta_data  Json
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  order  Order[]

  @@map("transactions")
}

model Upload {
  id  Int
  url  String
  provider  String
  source_id  String
  meta_data  Json
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  advert  Advert[]
  brand  Brand[]
  category  Category[]

  @@map("uploads")
}

model User {
  id  Int
  auth_id  Int
  avatar_id  Int
  first_name  String
  last_name  String
  other_name  String
  gender  String
  dob  String
  address  String
  city  String
  country  String
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  phone_number  String
  state  String
  location  Int
  auth  Auth  @relation(fields: [auth_id], references: [id])
  promoLike  PromoLike[]
  userAnalytic  UserAnalytic[]
  userRole  UserRole[]
  userSetting  UserSetting[]

  @@map("users")
}

model UserAnalytic {
  id  Int
  date  DateTime
  user_id  Int
  saved_promos  Int
  redeemed_promos  Int
  feedback_given  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  user  User  @relation(fields: [user_id], references: [id])

  @@map("user_analytics")
}

model UserRole {
  id  Int
  user_id  Int
  brand_id  Int
  role_id  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  user  User  @relation(fields: [user_id], references: [id])

  @@map("user_roles")
}

model UserSetting {
  id  Int
  user_id  Int
  language  String
  push_notifications  Int
  email_notifications  Int
  location_access  Int
  weekly_promo_drop_alert  Int
  brand_ad_hoc_notification  Int
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime
  auto_sync_location  Int
  use_face_id  Int
  use_fingerprint_id  Int
  user  User  @relation(fields: [user_id], references: [id])

  @@map("user_settings")
}

model Wallet {
  id  Int
  brand_id  Int
  balance  Float
  ledger  Float
  created_at  DateTime
  updated_at  DateTime
  deleted_at  DateTime

  @@map("wallets")
}